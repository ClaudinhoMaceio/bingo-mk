<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover" />
<title>Bingo Online — Globo Real, 50 Cartelas, PWA</title>
<meta name="description" content="Jogo de bingo online gratuito com globo animado, 50 cartelas predefinidas, modo Globo (apresentador) ou Usuário (jogador) integrado em rede local." />
<meta name="theme-color" content="#0b1020" />
<link rel="manifest" href="/manifest.webmanifest" />
<link rel="icon" href="/bingo-icon.svg" type="image/svg+xml" />
<link rel="apple-touch-icon" href="/bingo-icon.svg" />
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700;900&family=Bungee&family=Special+Elite&display=swap" rel="stylesheet">
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#070b1a;--panel:#121a3a;--panel2:#1a2350;
  --text:#eef2ff;--muted:#8a96c8;--accent:#ffd166;--ok:#06d6a0;
  --shadow:0 20px 60px -20px rgba(0,0,0,.6);
}
html,body{height:100%}
body{font-family:'Inter',system-ui,sans-serif;color:var(--text);
  background:radial-gradient(1200px 600px at 80% -10%,#1b2660 0%,transparent 60%),radial-gradient(900px 500px at -10% 110%,#2a1554 0%,transparent 60%),var(--bg);
  min-height:100%;overflow-x:hidden;
  padding:env(safe-area-inset-top) env(safe-area-inset-right) env(safe-area-inset-bottom) env(safe-area-inset-left);
  -webkit-tap-highlight-color:transparent;-webkit-text-size-adjust:100%}
.app{display:grid;grid-template-columns:1fr;gap:16px;padding:14px;max-width:1400px;margin:0 auto}
@media(min-width:1024px){.app{grid-template-columns:1.1fr 1fr;gap:20px;padding:20px}}
/* MODO USUÁRIO: foco total na cartela */
body.role-user .app{grid-template-columns:1fr;max-width:780px;padding:10px;gap:12px}
body.role-user .globe-wrap{padding:10px;background:transparent;border:none;box-shadow:none;gap:8px}
body.role-user .globe,body.role-user .history{display:none}
body.role-user #cardSelectorPanel,body.role-user #panelGlobo{display:none!important}
body.role-user .right .panel:first-child{padding:10px}
body.role-user .stat .pill{font-size:11px;padding:6px 10px}
header.top{grid-column:1/-1;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px}
.brand{display:flex;align-items:center;gap:12px}
.logo{width:44px;height:44px;border-radius:12px;background:linear-gradient(135deg,#ef476f,#ffd166);display:grid;place-items:center;font-weight:900;color:#0b1020;box-shadow:var(--shadow)}
h1{font-size:22px;letter-spacing:.5px}
.sub{color:var(--muted);font-size:12px}
.controls{display:flex;gap:8px;flex-wrap:wrap}
button{font-family:inherit;font-weight:700;font-size:14px;color:var(--text);
  background:linear-gradient(180deg,var(--panel2),var(--panel));border:1px solid rgba(255,255,255,.08);
  border-radius:12px;padding:10px 14px;cursor:pointer;transition:transform .1s,filter .2s;box-shadow:var(--shadow)}
button:hover{filter:brightness(1.15)}button:active{transform:translateY(1px)}
button.primary{background:linear-gradient(135deg,#ef476f,#ffd166);color:#0b1020;border:none}
button.ghost{background:transparent;border:1px solid rgba(255,255,255,.15)}
.panel{background:linear-gradient(180deg,rgba(255,255,255,.04),rgba(255,255,255,.02));border:1px solid rgba(255,255,255,.08);border-radius:20px;padding:18px;box-shadow:var(--shadow)}

/* GLOBE */
.globe-wrap{display:flex;flex-direction:column;align-items:center;gap:16px}
.globe{position:relative;width:min(90vw,460px);aspect-ratio:1;border-radius:50%;
  background:radial-gradient(circle at 30% 25%,rgba(255,255,255,.18),transparent 40%),radial-gradient(circle at 70% 80%,rgba(0,0,0,.5),transparent 50%),conic-gradient(from 0deg,#1a2350,#0c1230,#1a2350);
  border:6px solid rgba(255,255,255,.08);box-shadow:inset 0 0 80px rgba(0,0,0,.6),0 30px 80px -20px rgba(239,71,111,.25);overflow:hidden}
.globe::before{content:"";position:absolute;inset:6%;border-radius:50%;border:2px dashed rgba(255,255,255,.06)}
.globe.spin .balls{animation:spin 6s linear infinite}
.balls{position:absolute;inset:0}
.ball{position:absolute;width:42px;height:42px;border-radius:50%;display:grid;place-items:center;font-weight:900;font-size:14px;color:#0b1020;
  box-shadow:inset -6px -8px 12px rgba(0,0,0,.25),inset 6px 6px 10px rgba(255,255,255,.35),0 6px 12px rgba(0,0,0,.4);transform:translate(-50%,-50%)}
.ball.B{background:radial-gradient(circle at 30% 30%,#ffb1c4,#ef476f)}
.ball.I{background:radial-gradient(circle at 30% 30%,#ffe7a8,#ffd166)}
.ball.N{background:radial-gradient(circle at 30% 30%,#a8f0d8,#06d6a0)}
.ball.G{background:radial-gradient(circle at 30% 30%,#a8d8e8,#118ab2);color:#fff}
.ball.O{background:radial-gradient(circle at 30% 30%,#d8b8f0,#9b5de5);color:#fff}
@keyframes spin{to{transform:rotate(360deg)}}
.tube{position:absolute;left:50%;bottom:-2px;transform:translateX(-50%);width:28%;height:18%;border-top-left-radius:30px;border-top-right-radius:30px;background:linear-gradient(180deg,rgba(255,255,255,.08),rgba(255,255,255,.02));border:1px solid rgba(255,255,255,.1);border-bottom:none}
.current{display:flex;align-items:center;gap:18px;justify-content:center}
.current .ball{position:static;transform:none;width:90px;height:90px;font-size:30px}
.current .letter{font-size:48px;font-weight:900;color:var(--accent);text-shadow:0 4px 20px rgba(255,209,102,.4)}
.history{display:flex;flex-wrap:wrap;gap:6px;justify-content:center;max-width:460px}
.history .mini{width:34px;height:34px;border-radius:50%;display:grid;place-items:center;font-size:11px;font-weight:800;color:#0b1020}
.history .mini.B{background:#ef476f;color:#fff}.history .mini.I{background:#ffd166}
.history .mini.N{background:#06d6a0}.history .mini.G{background:#118ab2;color:#fff}
.history .mini.O{background:#9b5de5;color:#fff}

/* USER: bola sorteada estilo cabine */
body.role-user .current{background:linear-gradient(180deg,#1a2350,#0c1230);padding:14px 22px;border-radius:18px;border:1px solid rgba(255,209,102,.3);box-shadow:0 0 40px rgba(255,209,102,.15)}

/* RIGHT */
.right{display:flex;flex-direction:column;gap:16px}
.row{display:flex;gap:10px;align-items:center;flex-wrap:wrap}
.row label{color:var(--muted);font-size:12px}
select{font-family:inherit;background:var(--panel);color:var(--text);border:1px solid rgba(255,255,255,.12);border-radius:10px;padding:8px 12px;font-size:14px}
.stat{display:flex;gap:14px;flex-wrap:wrap}
.stat .pill{background:var(--panel);padding:8px 12px;border-radius:10px;font-size:12px;color:var(--muted)}
.stat .pill b{color:var(--text);font-size:14px;margin-left:6px}

/* ===== CARTELA padrão (modo globo) ===== */
.cards{display:grid;grid-template-columns:1fr;gap:14px}
.card{background:linear-gradient(180deg,#fafbff,#e9ecff);color:#0b1020;border-radius:18px;padding:14px;box-shadow:var(--shadow);position:relative;overflow:hidden}
.card .head{display:flex;justify-content:space-between;align-items:center;margin-bottom:8px}
.card .num{font-weight:900;font-size:14px;letter-spacing:1px;color:#3b4280}
.card .actions{display:flex;gap:6px}
.card .actions button{padding:4px 10px;font-size:12px;background:#0b1020;color:#fff;border:none;border-radius:8px;box-shadow:none}
.bingo-header{display:grid;grid-template-columns:repeat(5,1fr);gap:6px;margin-bottom:6px}
.bingo-header span{text-align:center;font-weight:900;font-size:20px;padding:8px 0;border-radius:10px;color:#fff}
.bingo-header span:nth-child(1){background:#ef476f}
.bingo-header span:nth-child(2){background:#ffd166;color:#0b1020}
.bingo-header span:nth-child(3){background:#06d6a0;color:#0b1020}
.bingo-header span:nth-child(4){background:#118ab2}
.bingo-header span:nth-child(5){background:#9b5de5}
.grid{display:grid;grid-template-columns:repeat(5,1fr);gap:6px}
.cell{aspect-ratio:1;background:#fff;border-radius:10px;display:grid;place-items:center;font-weight:800;font-size:18px;color:#1a2350;border:1px solid #d8def0;cursor:pointer;transition:transform .08s;user-select:none}
.cell:hover{transform:scale(1.03)}
.cell.free{background:linear-gradient(135deg,#ffd166,#ef476f);color:#0b1020}
.cell.marked{background:linear-gradient(135deg,#06d6a0,#118ab2);color:#fff;border-color:transparent;position:relative}
.cell.marked::after{content:"";position:absolute;inset:6px;border-radius:50%;border:3px solid rgba(255,255,255,.6)}
.card.win{outline:4px solid #ffd166;box-shadow:0 0 60px rgba(255,209,102,.6)}

/* ===== CARTELA CLÁSSICA (modo usuário) - estilo bingo tradicional ===== */
body.role-user .cards .card{
  max-width:560px;margin:0 auto;
  background:
    repeating-linear-gradient(0deg,transparent 0 28px,rgba(0,0,0,.03) 28px 29px),
    linear-gradient(180deg,#fffbe8,#f5ebc6);
  color:#1a0e00;
  border:3px solid #7a1e1e;
  border-radius:14px;
  padding:18px;
  box-shadow:0 25px 60px -10px rgba(0,0,0,.55),inset 0 0 0 6px #fff,inset 0 0 0 7px #7a1e1e;
  position:relative;
}
body.role-user .cards .card::before{
  content:"";position:absolute;inset:10px;border:2px dashed rgba(122,30,30,.35);border-radius:8px;pointer-events:none;
}
body.role-user .cards .card .head{
  border-bottom:2px solid #7a1e1e;padding-bottom:8px;margin-bottom:10px;
}
body.role-user .cards .card .num{
  font-family:'Special Elite',serif;color:#7a1e1e;font-size:16px;letter-spacing:2px;
}
body.role-user .bingo-header{gap:0;margin-bottom:0;background:#7a1e1e;border-radius:10px 10px 0 0;overflow:hidden;border:2px solid #7a1e1e}
body.role-user .bingo-header span{
  font-family:'Bungee',sans-serif;font-size:34px;padding:10px 0;border-radius:0;color:#fffbe8;background:transparent;
  border-right:2px solid #fffbe8;text-shadow:2px 2px 0 rgba(0,0,0,.3);letter-spacing:2px
}
body.role-user .bingo-header span:last-child{border-right:none}
body.role-user .bingo-header span:nth-child(n){background:transparent;color:#fffbe8}
body.role-user .grid{gap:0;border:2px solid #7a1e1e;border-top:none;border-radius:0 0 10px 10px;overflow:hidden;background:#7a1e1e}
body.role-user .cards .cell{
  aspect-ratio:1;background:#fffbe8;border-radius:0;border:1px solid #7a1e1e;
  font-family:'Special Elite','Courier New',monospace;font-weight:700;color:#1a0e00;
  box-shadow:inset 0 0 0 2px #fffbe8;
  font-size:clamp(20px,6vw,34px);
}
body.role-user .cards .cell.free{
  background:#fffbe8;color:#7a1e1e;font-size:clamp(14px,3.5vw,18px);
}
body.role-user .cards .cell.free::before{
  content:"FREE";font-family:'Bungee',sans-serif;font-size:clamp(12px,3vw,16px);letter-spacing:1px;
  position:absolute;
}
body.role-user .cards .cell.free{position:relative;display:grid;place-items:center}
body.role-user .cards .cell.marked{background:#fffbe8;color:#1a0e00;position:relative;border-color:#7a1e1e}
body.role-user .cards .cell.marked::after{
  content:"";position:absolute;left:50%;top:50%;width:78%;height:78%;
  transform:translate(-50%,-50%);border-radius:50%;
  background:radial-gradient(circle at 35% 30%,rgba(255,255,255,.45),rgba(220,20,60,.85) 55%,rgba(120,0,20,.95));
  border:none;box-shadow:0 3px 6px rgba(0,0,0,.4),inset 0 -4px 8px rgba(0,0,0,.3);
  mix-blend-mode:multiply;opacity:.92;
}
body.role-user .cards .cell.marked{color:#fffbe8;text-shadow:0 1px 2px rgba(0,0,0,.6)}
body.role-user .cards .cell:hover{transform:none;filter:brightness(.97)}
/* DESTAQUE: célula que corresponde ao número sorteado e ainda não marcada */
.cell.hint{animation:hintPulse 1.2s ease-in-out infinite;outline:3px solid #ffd166;outline-offset:-2px;z-index:1}
body.role-user .cards .cell.hint{outline:4px solid #ffd166;box-shadow:0 0 0 4px rgba(255,209,102,.35),0 0 18px rgba(255,209,102,.7) inset}
@keyframes hintPulse{0%,100%{filter:brightness(1)}50%{filter:brightness(1.25) saturate(1.3)}}

.tabs{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:8px;max-height:120px;overflow:auto}
.tab{padding:6px 10px;border-radius:8px;background:var(--panel);font-size:12px;cursor:pointer;border:1px solid transparent}
.tab.active{border-color:var(--accent);color:var(--accent)}

.winOverlay{position:fixed;inset:0;display:none;place-items:center;background:rgba(7,11,26,.85);z-index:50;backdrop-filter:blur(8px);padding:20px}
.winOverlay.on{display:grid}
.winBox{background:linear-gradient(135deg,#1a2350,#0c1230);border:1px solid rgba(255,209,102,.4);border-radius:24px;padding:24px;max-width:520px;width:100%;text-align:center;box-shadow:0 30px 100px rgba(0,0,0,.6)}
.winBox h2{font-size:34px;background:linear-gradient(135deg,#ffd166,#ef476f);-webkit-background-clip:text;background-clip:text;color:transparent;margin-bottom:6px}
.winBox p{color:var(--muted);margin-bottom:14px}
.winBox .card{margin:0 auto;max-width:380px}
footer{grid-column:1/-1;text-align:center;color:var(--muted);font-size:12px;padding:10px}
.net{display:inline-flex;align-items:center;gap:6px;font-size:11px;color:var(--muted)}
.dot{width:8px;height:8px;border-radius:50%;background:var(--ok)}
.confetti{position:fixed;inset:0;pointer-events:none;z-index:60;overflow:hidden}
.confetti i{position:absolute;width:10px;height:14px;top:-20px;animation:fall 3s linear forwards}
@keyframes fall{to{transform:translateY(110vh) rotate(720deg)}}

.roleScreen{position:fixed;inset:0;display:none;place-items:center;background:radial-gradient(1000px 600px at 30% 0%,#241452,transparent),radial-gradient(800px 600px at 80% 100%,#3a0e3c,transparent),#070b1a;z-index:80;padding:20px;overflow:auto}
.roleScreen.on{display:grid}
.roleBox{background:linear-gradient(180deg,rgba(255,255,255,.05),rgba(255,255,255,.02));border:1px solid rgba(255,255,255,.1);border-radius:24px;padding:28px;max-width:820px;width:100%;box-shadow:var(--shadow)}
.roleGrid{display:grid;grid-template-columns:1fr;gap:14px}
@media(min-width:640px){.roleGrid{grid-template-columns:1fr 1fr}}
.roleCard{text-align:left;background:linear-gradient(180deg,#1a2350,#0f1530);border:1px solid rgba(255,255,255,.1);border-radius:18px;padding:22px;cursor:pointer;transition:transform .15s,border-color .2s;color:var(--text);font-family:inherit}
.roleCard:hover{transform:translateY(-3px);border-color:var(--accent)}
.roleCard .icon{font-size:42px;margin-bottom:10px}
.roleCard h3{font-size:18px;margin-bottom:6px}
.roleCard p{color:var(--muted);font-size:13px;line-height:1.5}
.cardPicker{position:fixed;inset:0;display:none;place-items:center;padding:20px;overflow:auto;background:rgba(7,11,26,.96);z-index:90}
.cardPicker.on{display:grid}
.pickGrid{display:grid;grid-template-columns:repeat(auto-fill,minmax(72px,1fr));gap:8px;max-height:60vh;overflow:auto;padding:4px}
.pickCard{padding:14px 8px;background:linear-gradient(135deg,#1a2350,#0f1530);border:1px solid rgba(255,255,255,.1);border-radius:12px;color:var(--text);font-weight:800;cursor:pointer;font-family:inherit;font-size:14px;transition:all .15s}
.pickCard:hover{background:linear-gradient(135deg,#ffd166,#ef476f);color:#0b1020;border-color:transparent;transform:scale(1.05)}
</style>
</head>
<body>

<div class="roleScreen on" id="roleScreen">
  <div class="roleBox">
    <div class="brand" style="justify-content:center;margin-bottom:18px">
      <div class="logo">B</div>
      <h1 style="font-size:26px">Bingo Online</h1>
    </div>
    <p class="sub" style="text-align:center;margin-bottom:22px">Escolha como deseja entrar — tudo integrado em tempo real na mesma rede</p>
    <div class="roleGrid">
      <button class="roleCard" id="chooseGlobo">
        <div class="icon">🎱</div><h3>Entrar como GLOBO</h3>
        <p>Apresentador: sorteia as bolas, controla o jogo e vê todas as cartelas em jogo.</p>
      </button>
      <button class="roleCard" id="chooseUser">
        <div class="icon">🎟</div><h3>Entrar como USUÁRIO</h3>
        <p>Jogador: escolha o número da sua cartela e jogue na cartela clássica do bingo.</p>
      </button>
    </div>
  </div>

  <div class="cardPicker" id="cardPicker">
    <div class="roleBox" style="max-width:720px">
      <h2 style="text-align:center;margin-bottom:6px">Escolha o número da sua cartela</h2>
      <p class="sub" style="text-align:center;margin-bottom:16px">50 cartelas predefinidas. Você jogará com a cartela escolhida.</p>
      <div class="pickGrid" id="cardPickerGrid"></div>
      <div style="text-align:center;margin-top:16px"><button class="ghost" id="backRole">Voltar</button></div>
    </div>
  </div>
</div>

<div class="app" id="app" style="display:none">
  <header class="top">
    <div class="brand">
      <div class="logo">B</div>
      <div><h1>Bingo Online</h1>
        <div class="sub"><span id="roleBadge"></span> · <span class="net"><span class="dot"></span>rede local ativa</span></div>
      </div>
    </div>
    <div class="controls">
      <div id="controlsGlobo" style="display:flex;gap:8px;flex-wrap:wrap">
        <button id="btnDraw" class="primary">🎱 Sortear bola</button>
        <button id="btnAuto">▶ Automático</button>
        <button id="btnReset" class="ghost">↻ Reiniciar</button>
      </div>
      <button id="switchRole" class="ghost">↔ Trocar papel</button>
    </div>
  </header>

  <section class="panel globe-wrap">
    <div class="globe" id="globe"><div class="balls" id="balls"></div><div class="tube"></div></div>
    <div class="current" id="current"><div class="letter">—</div></div>
    <div class="history" id="history"></div>
    <div id="globeWinner"></div>
  </section>

  <aside class="right">
    <section class="panel">
      <div class="row" style="justify-content:space-between">
        <div class="stat">
          <div class="pill">Sorteadas <b id="drawnCount">0</b></div>
          <div class="pill">Restantes <b id="remaining">75</b></div>
          <div class="pill">Vencedoras <b id="winners">—</b></div>
        </div>
      </div>
      <hr style="border:none;border-top:1px solid rgba(255,255,255,.08);margin:12px 0" />
      <div class="row" id="panelGlobo">
        <label>Velocidade</label>
        <select id="speed">
          <option value="5000">Lenta (5s)</option>
          <option value="3500" selected>Normal (3.5s)</option>
          <option value="2000">Rápida (2s)</option>
          <option value="1000">Turbo (1s)</option>
        </select>
        <label>Modo de vitória</label>
        <select id="mode">
          <option value="full" selected>Cartela cheia</option>
          <option value="line">Linha / Coluna / Diagonal</option>
        </select>
        <label><input type="checkbox" id="autoMark" /> Marcar automaticamente</label>
      </div>
    </section>

    <section class="panel" id="cardSelectorPanel">
      <div class="row" style="justify-content:space-between;margin-bottom:8px">
        <strong>Cartelas em jogo (50 predefinidas)</strong>
        <div class="controls">
          <button id="random3" class="ghost">🎲 3 aleatórias</button>
          <button id="selectAll" class="ghost">Todas</button>
          <button id="clearSel" class="ghost">Limpar</button>
        </div>
      </div>
      <div class="tabs" id="tabs"></div>
    </section>

    <section class="panel"><div class="cards" id="cards"></div></section>
  </aside>

  <footer>Bingo Online © — Funciona offline (PWA) · Globo e Usuários sincronizam em tempo real na mesma rede</footer>
</div>

<div class="winOverlay" id="winOverlay"><div class="winBox" id="winBox"></div></div>
<div class="confetti" id="confetti"></div>

<script>
const LETTERS=['B','I','N','G','O'];
const RANGES={B:[1,15],I:[16,30],N:[31,45],G:[46,60],O:[61,75]};
function mulberry32(a){return function(){let t=a+=0x6D2B79F5;t=Math.imul(t^t>>>15,t|1);t^=t+Math.imul(t^t>>>7,t|61);return ((t^t>>>14)>>>0)/4294967296;}}
function shuffle(a,r){for(let i=a.length-1;i>0;i--){const j=Math.floor(r()*(i+1));[a[i],a[j]]=[a[j],a[i]]}return a}
function generateCard(seed){const r=mulberry32(seed);const cols=LETTERS.map(L=>{const[lo,hi]=RANGES[L];const p=[];for(let n=lo;n<=hi;n++)p.push(n);return shuffle(p,r).slice(0,5)});cols[2][2]='FREE';const g=[];for(let i=0;i<5;i++){const row=[];for(let c=0;c<5;c++)row.push(cols[c][i]);g.push(row)}return g}
const CARDS=Array.from({length:50},(_,i)=>({id:i+1,grid:generateCard(1000+i)}));

function shuffleAll(){const a=[];for(let n=1;n<=75;n++)a.push(n);for(let i=a.length-1;i>0;i--){const j=Math.floor(Math.random()*(i+1));[a[i],a[j]]=[a[j],a[i]]}return a}
function letterFor(n){for(const L of LETTERS){const[lo,hi]=RANGES[L];if(n>=lo&&n<=hi)return L}}
function loadMarks(){try{const v=JSON.parse(localStorage.getItem('bingo.marks'))||{};const o={};for(const k in v)o[k]=new Set(v[k]);return o}catch{return{}}}
function saveMarks(){const o={};for(const k in state.marks)o[k]=[...state.marks[k]];localStorage.setItem('bingo.marks',JSON.stringify(o))}

const state={
  role:localStorage.getItem('bingo.role')||null,
  userCardId:+localStorage.getItem('bingo.userCard')||null,
  drawn:[],available:shuffleAll(),spinning:false,autoTimer:null,
  speed:3500,winMode:'full',selectedCardIds:[],marks:loadMarks(),autoMark:false,winners:[]
};

const bc=('BroadcastChannel'in window)?new BroadcastChannel('bingo-room'):null;
function netSend(m){try{bc&&bc.postMessage(m)}catch{}}
if(bc){bc.onmessage=(e)=>{const m=e.data;
  if(m.type==='draw')applyRemoteDraw(m.n);
  if(m.type==='reset')doReset(false);
  if(m.type==='sync-request'&&state.role==='globo')netSend({type:'sync-state',drawn:state.drawn});
  if(m.type==='sync-state'&&state.drawn.length===0&&m.drawn.length)m.drawn.forEach(d=>applyRemoteDraw(d.n));
  if(m.type==='winner')showWinnerFromRemote(m.cardId);
}}

const $=s=>document.querySelector(s);

function showRoleScreen(){$('#roleScreen').classList.add('on');$('#app').style.display='none'}
function hideRoleScreen(){$('#roleScreen').classList.remove('on');$('#app').style.display='grid'}
function applyRole(){
  const isGlobo=state.role==='globo';
  document.body.classList.toggle('role-globo',isGlobo);
  document.body.classList.toggle('role-user',!isGlobo);
  $('#roleBadge').textContent=isGlobo?'🎱 GLOBO (Apresentador)':'🎟 USUÁRIO — Cartela #'+String(state.userCardId).padStart(2,'0');
  $('#controlsGlobo').style.display=isGlobo?'flex':'none';
  $('#panelGlobo').style.display=isGlobo?'flex':'none';
  $('#cardSelectorPanel').style.display=isGlobo?'block':'none';
  if(!isGlobo){state.selectedCardIds=[state.userCardId]}
  else{try{const v=JSON.parse(localStorage.getItem('bingo.sel'));state.selectedCardIds=Array.isArray(v)?v:[]}catch{state.selectedCardIds=[]}}
  renderTabs();renderCards();
  if(!isGlobo)netSend({type:'sync-request'});
}

const ballsEl=()=>$('#balls'),currentEl=()=>$('#current'),historyEl=()=>$('#history'),
      cardsEl=()=>$('#cards'),tabsEl=()=>$('#tabs'),drawnCountEl=()=>$('#drawnCount'),
      remainingEl=()=>$('#remaining'),winnersEl=()=>$('#winners'),globeEl=()=>$('#globe');

function renderGlobeBalls(){
  const el=ballsEl();if(!el)return;el.innerHTML='';
  const rem=state.available.slice(0,18);const W=el.clientWidth,H=el.clientHeight,R=W/2-28;
  rem.forEach((n,i)=>{const ang=(i/rem.length)*Math.PI*2;const r=R*(0.35+0.55*Math.random());
    const x=W/2+Math.cos(ang)*r,y=H/2+Math.sin(ang)*r;const L=letterFor(n);
    const b=document.createElement('div');b.className=`ball ${L}`;b.style.left=x+'px';b.style.top=y+'px';b.textContent=n;el.appendChild(b)})
}
window.addEventListener('resize',renderGlobeBalls);

function drawNext(){
  if(state.role!=='globo')return;
  if(state.available.length===0)return;
  globeEl().classList.add('spin');state.spinning=true;
  setTimeout(()=>{const n=state.available.shift();applyDraw(n);netSend({type:'draw',n});globeEl().classList.remove('spin');state.spinning=false},900);
}
function applyDraw(n){const L=letterFor(n);state.drawn.push({n,letter:L});renderCurrent(n,L);renderHistory();renderGlobeBalls();updateStats();if(state.autoMark)autoMarkAll(n);else renderCards();checkWinners();speak(`${L}, ${n}`)}
function applyRemoteDraw(n){if(state.drawn.some(d=>d.n===n))return;state.available=state.available.filter(x=>x!==n);applyDraw(n)}
function renderCurrent(n,L){currentEl().innerHTML=`<div class="letter">${L}</div><div class="ball ${L}">${n}</div><div class="letter">${n}</div>`}
function renderHistory(){const el=historyEl();el.innerHTML='';state.drawn.slice().reverse().forEach(d=>{const e=document.createElement('div');e.className=`mini ${d.letter}`;e.textContent=`${d.letter}${d.n}`;el.appendChild(e)})}
function updateStats(){drawnCountEl().textContent=state.drawn.length;remainingEl().textContent=75-state.drawn.length}
function speak(t){if(!('speechSynthesis'in window))return;try{const u=new SpeechSynthesisUtterance(t);u.lang='pt-BR';u.rate=.95;speechSynthesis.cancel();speechSynthesis.speak(u)}catch{}}

function renderTabs(){const el=tabsEl();if(!el)return;el.innerHTML='';if(state.role!=='globo')return;
  CARDS.forEach(c=>{const t=document.createElement('div');t.className='tab'+(state.selectedCardIds.includes(c.id)?' active':'');t.textContent='#'+String(c.id).padStart(2,'0');
    t.onclick=()=>{if(state.selectedCardIds.includes(c.id))state.selectedCardIds=state.selectedCardIds.filter(x=>x!==c.id);else state.selectedCardIds.push(c.id);
      localStorage.setItem('bingo.sel',JSON.stringify(state.selectedCardIds));renderTabs();renderCards()};el.appendChild(t)})}
function renderCards(){const el=cardsEl();if(!el)return;el.innerHTML='';
  state.selectedCardIds.forEach(id=>{const card=CARDS.find(c=>c.id===id);if(!card)return;
    const marks=state.marks[id]||(state.marks[id]=new Set(['FREE']));
    const c=document.createElement('div');c.className='card'+(state.winners.includes(id)?' win':'');
    c.innerHTML=`<div class="head"><div class="num">CARTELA #${String(id).padStart(2,'0')}</div><div class="actions"><button data-clear="${id}">Limpar</button></div></div>
      <div class="bingo-header"><span>B</span><span>I</span><span>N</span><span>G</span><span>O</span></div>
      <div class="grid">${card.grid.flat().map(v=>{const f=v==='FREE';const m=f||marks.has(v);const lastN=state.drawn.length?state.drawn[state.drawn.length-1].n:null;const hint=!m&&!f&&v===lastN;return `<div class="cell ${f?'free':''} ${m?'marked':''} ${hint?'hint':''}" data-card="${id}" data-val="${v}">${f?'':v}</div>`}).join('')}</div>`;
    el.appendChild(c)});
  el.querySelectorAll('.cell').forEach(c=>{c.onclick=()=>{const id=+c.dataset.card;const v=c.dataset.val;if(v==='FREE')return;
    const set=state.marks[id]||(state.marks[id]=new Set(['FREE']));const num=+v;
    if(set.has(num))set.delete(num);else set.add(num);saveMarks();renderCards();checkWinners()}});
  el.querySelectorAll('[data-clear]').forEach(b=>b.onclick=()=>{const id=+b.dataset.clear;state.marks[id]=new Set(['FREE']);state.winners=state.winners.filter(w=>w!==id);saveMarks();renderCards()});
}
function autoMarkAll(n){state.selectedCardIds.forEach(id=>{const card=CARDS.find(c=>c.id===id);if(!card)return;if(card.grid.flat().includes(n)){const set=state.marks[id]||(state.marks[id]=new Set(['FREE']));set.add(n)}});saveMarks();renderCards()}

function isWinner(card,marks){const g=card.grid;const has=v=>v==='FREE'||marks.has(v);
  if(state.winMode==='full')return g.flat().every(has);
  for(let r=0;r<5;r++)if(g[r].every(has))return true;
  for(let c=0;c<5;c++)if([0,1,2,3,4].every(r=>has(g[r][c])))return true;
  if([0,1,2,3,4].every(i=>has(g[i][i])))return true;
  if([0,1,2,3,4].every(i=>has(g[i][4-i])))return true;return false}
function checkWinners(){for(const id of state.selectedCardIds){if(state.winners.includes(id))continue;
  const card=CARDS.find(c=>c.id===id);const marks=state.marks[id]||new Set(['FREE']);
  const drawn=new Set(state.drawn.map(d=>d.n));const valid=[...marks].every(v=>v==='FREE'||drawn.has(v));
  if(valid&&isWinner(card,marks)){state.winners.push(id);announceWin(id);netSend({type:'winner',cardId:id})}}
  if(winnersEl())winnersEl().textContent=state.winners.length?state.winners.map(i=>'#'+String(i).padStart(2,'0')).join(', '):'—';renderCards()}
function showWinnerFromRemote(cid){if(!state.winners.includes(cid))state.winners.push(cid);announceWin(cid);if(winnersEl())winnersEl().textContent=state.winners.map(i=>'#'+String(i).padStart(2,'0')).join(', ')}
function announceWin(id){pauseAuto();const card=CARDS.find(c=>c.id===id);speak('Bingo! Cartela '+id);
  const marks=state.marks[id]||new Set(['FREE']);const ds=new Set(state.drawn.map(d=>d.n));
  card.grid.flat().forEach(v=>{if(v!=='FREE'&&ds.has(v))marks.add(v)});
  const wb=$('#winBox');wb.innerHTML=`<h2>🎉 BINGO!</h2><p>Cartela vencedora <b>#${String(id).padStart(2,'0')}</b></p>
    <div class="card win"><div class="bingo-header"><span>B</span><span>I</span><span>N</span><span>G</span><span>O</span></div>
    <div class="grid">${card.grid.flat().map(v=>{const f=v==='FREE';const m=f||marks.has(v);return `<div class="cell ${f?'free':''} ${m?'marked':''}">${f?'★':v}</div>`}).join('')}</div></div>
    <div style="margin-top:14px;display:flex;gap:8px;justify-content:center"><button class="primary" id="closeWin">Continuar</button></div>`;
  $('#winOverlay').classList.add('on');$('#closeWin').onclick=()=>$('#winOverlay').classList.remove('on');
  const gw=$('#globeWinner');if(gw){gw.innerHTML=`<div class="card win" style="max-width:260px;margin-top:12px">
    <div class="num" style="text-align:center;margin-bottom:6px">VENCEDORA #${String(id).padStart(2,'0')}</div>
    <div class="bingo-header"><span>B</span><span>I</span><span>N</span><span>G</span><span>O</span></div>
    <div class="grid">${card.grid.flat().map(v=>{const f=v==='FREE';const m=f||marks.has(v);return `<div class="cell ${f?'free':''} ${m?'marked':''}" style="font-size:12px">${f?'★':v}</div>`}).join('')}</div></div>`}
  fireConfetti()}
function fireConfetti(){const c=document.getElementById('confetti');c.innerHTML='';const cl=['#ef476f','#ffd166','#06d6a0','#118ab2','#9b5de5'];
  for(let i=0;i<120;i++){const s=document.createElement('i');s.style.left=(Math.random()*100)+'%';s.style.background=cl[i%cl.length];s.style.animationDelay=(Math.random()*1.5)+'s';s.style.transform=`rotate(${Math.random()*360}deg)`;c.appendChild(s)}
  setTimeout(()=>c.innerHTML='',4000)}

function startAuto(){if(state.role!=='globo')return;if(state.autoTimer)return;$('#btnAuto').textContent='⏸ Pausar';const tick=()=>{drawNext();state.autoTimer=setTimeout(tick,state.speed)};tick()}
function pauseAuto(){if(!state.autoTimer)return;clearTimeout(state.autoTimer);state.autoTimer=null;const b=$('#btnAuto');if(b)b.textContent='▶ Automático'}
function toggleAuto(){state.autoTimer?pauseAuto():startAuto()}
function doReset(broadcast=true){pauseAuto();state.drawn=[];state.available=shuffleAll();state.winners=[];
  state.selectedCardIds.forEach(id=>state.marks[id]=new Set(['FREE']));saveMarks();
  if(currentEl())currentEl().innerHTML='<div class="letter">—</div>';if(historyEl())historyEl().innerHTML='';
  const gw=$('#globeWinner');if(gw)gw.innerHTML='';updateStats();renderCards();renderGlobeBalls();
  if(broadcast)netSend({type:'reset'});if(winnersEl())winnersEl().textContent='—'}

function buildCardPicker(){const el=$('#cardPickerGrid');el.innerHTML='';
  CARDS.forEach(c=>{const b=document.createElement('button');b.className='pickCard';b.textContent='#'+String(c.id).padStart(2,'0');
    b.onclick=()=>{state.userCardId=c.id;state.role='usuario';localStorage.setItem('bingo.role','usuario');localStorage.setItem('bingo.userCard',c.id);hideRoleScreen();applyRole()};el.appendChild(b)})}

window.addEventListener('DOMContentLoaded',()=>{
  buildCardPicker();
  $('#chooseGlobo').onclick=()=>{state.role='globo';localStorage.setItem('bingo.role','globo');hideRoleScreen();applyRole()};
  $('#chooseUser').onclick=()=>$('#cardPicker').classList.add('on');
  $('#backRole').onclick=()=>$('#cardPicker').classList.remove('on');
  $('#switchRole').onclick=()=>{localStorage.removeItem('bingo.role');state.role=null;showRoleScreen()};
  $('#btnDraw').onclick=()=>!state.spinning&&drawNext();
  $('#btnAuto').onclick=toggleAuto;
  $('#btnReset').onclick=()=>doReset(true);
  $('#speed').onchange=e=>{state.speed=+e.target.value};
  $('#mode').onchange=e=>{state.winMode=e.target.value;state.winners=[];checkWinners()};
  $('#autoMark').onchange=e=>{state.autoMark=e.target.checked};
  $('#random3').onclick=()=>{const ids=CARDS.map(c=>c.id).sort(()=>Math.random()-.5).slice(0,3);state.selectedCardIds=ids;localStorage.setItem('bingo.sel',JSON.stringify(ids));renderTabs();renderCards()};
  $('#selectAll').onclick=()=>{state.selectedCardIds=CARDS.map(c=>c.id);localStorage.setItem('bingo.sel',JSON.stringify(state.selectedCardIds));renderTabs();renderCards()};
  $('#clearSel').onclick=()=>{state.selectedCardIds=[];localStorage.setItem('bingo.sel','[]');renderTabs();renderCards()};
  updateStats();setTimeout(renderGlobeBalls,50);
  if(state.role){hideRoleScreen();applyRole()}else{showRoleScreen()}
  const h=location.hostname;const isPreview=h.startsWith('id-preview--')||h.startsWith('preview--')||h.endsWith('.lovableproject.com')||h.endsWith('.lovableproject-dev.com')||h.endsWith('.beta.lovable.dev')||window.top!==window.self;
  if('serviceWorker'in navigator){if(isPreview){navigator.serviceWorker.getRegistrations().then(rs=>rs.forEach(r=>r.unregister())).catch(()=>{})}else{navigator.serviceWorker.register('/sw.js').catch(()=>{})}}
});
</script>
